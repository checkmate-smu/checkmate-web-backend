# ===========================
# 로컬 개발 환경 설정 방법
# ===========================
# 이 파일은 참고용입니다.
# 실제 비밀값은 application-local.yml에 작성하세요.
#
# 1. src/main/resources/application-local.yml 파일 생성
# 2. 아래 내용을 채워 넣기:
#
# spring:
#   datasource:
#     url: jdbc:postgresql://HOST:PORT/DB
#     username: USER
#     password: PASSWORD
#
# 3. 실행:
#    ./gradlew bootRun --args='--spring.profiles.active=local'
#
# application-local.yml은 .gitignore에 포함되어 Git에 올라가지 않습니다.

# ===========================
# 배포 환경 (환경변수로 주입)
# ===========================
# SUPABASE_HOST=your_supabase_host
# SUPABASE_PORT=6543
# SUPABASE_DB=postgres
# SUPABASE_USER=postgres.your_ref
# SUPABASE_PASSWORD=your_password
# GEMINI_API_KEY=your_gemini_api_key
# GOOGLE_FACTCHECK_API_KEY=your_factcheck_api_key
# DEEPL_API_KEY=your_deepl_api_key
# SERVER_PORT=8080
